#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop and disable the service before removal
        if systemctl is-active --quiet knowloop 2>/dev/null; then
            systemctl stop knowloop || true
        fi
        if systemctl is-enabled --quiet knowloop 2>/dev/null; then
            systemctl disable knowloop || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
